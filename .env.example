# backup-agent configuration template.
# Copy this file to .env, replace the example values, and keep .env private.
# Boolean settings accept true, false, on, or off. Optional settings may be left empty.

# Application identity. Keep this as backup-agent for consistent service and CLI naming.
APP_NAME=backup-agent

# Source machine name used in notifications and destination folders.
# Leave empty to use the Windows hostname automatically, or set text such as sql-prod-01.
HOSTNAME=

# Minimum log level. Allowed values: debug, info, warn, error.
LOG_LEVEL=info

# Log directory. Leave empty to use <install-directory>\logs.
# Example custom value: D:\backup-agent\logs
LOG_DIR=

# State directory for the lock file, transfer history, and temporary compressed files.
# Leave empty to use <install-directory>\state.
STATE_DIR=

# Shared SOCKS proxy URL used when a feature-specific USE_PROXY setting is enabled.
# Formats: socks5://host:port or socks5://username:password@host:port.
PROXY_URL=socks5://127.0.0.1:1080

# Zip package downloaded by `backup-agent update`.
# The default always resolves to the newest GitHub release.
UPDATE_URL=https://github.com/behnambagheri/windows-file-backup-agent/releases/latest/download/backup-agent-windows.zip

# Route update package downloads through PROXY_URL.
# Allowed values: true, false, on, off.
UPDATE_USE_PROXY=false

# Enable the Prometheus HTTP endpoint. Allowed values: true, false, on, off.
METRICS_ENABLED=false

# Metrics listen address. Use 0.0.0.0 for remote scraping or 127.0.0.1 for local access only.
METRICS_HOST=0.0.0.0

# Metrics TCP port. Allowed range: 1-65535.
METRICS_PORT=9108

# Prometheus endpoint path. It must start with /. The health endpoint is always /healthz.
METRICS_PATH=/metrics

# Ask the installer to add a Windows Firewall inbound rule for METRICS_PORT.
# Allowed values: true, false, on, off. This only applies when METRICS_ENABLED=true.
METRICS_FIREWALL_RULE=false

# Display name used for the Windows Firewall rule.
METRICS_FIREWALL_RULE_NAME='backup-agent metrics'

# Six-field cron expression: second minute hour day-of-month month day-of-week.
# Examples: every 5 minutes = 0 */5 * * * *; daily at 02:30 = 0 30 2 * * *.
CRON_SCHEDULE='0 */5 * * * *'

# Run one transfer cycle immediately when the service starts. Allowed values: true, false, on, off.
RUN_ON_START=true

# Exit after one cycle. Keep false for the installed service; the CLI sets this for run-once.
RUN_ONCE=false

# Destination SSH server hostname or IP address.
DEST_HOST=192.0.2.10

# Destination SSH port. Allowed range: 1-65535.
DEST_PORT=22

# SSH account used to connect to the destination.
DEST_USER=backup-user

# Base destination directory on the remote server. Use a POSIX path such as /backups.
DEST_REMOTE_DIR=/backups

# Create an additional destination directory for each upload. Allowed values: true, false, on, off.
CREATE_DESTINATION_DIR=false

# Additional directory layout when CREATE_DESTINATION_DIR=true.
# Allowed values: date, hostname, hostname+date.
DESTINATION_DIR_FORMAT=date

# SSH authentication method. Allowed values: password, private_key.
DEST_AUTH_METHOD=password

# SSH password when DEST_AUTH_METHOD=password.
# When using private_key, leave empty unless the private key has a passphrase.
DEST_PASSWORD=change-me

# Full private key file encoded as one base64 string when DEST_AUTH_METHOD=private_key.
# Leave empty for password authentication.
# PowerShell command: [Convert]::ToBase64String([IO.File]::ReadAllBytes("C:\path\id_rsa"))
DEST_PRIVATE_KEY_BASE64=

# Maximum time in milliseconds to establish the SSH connection. Use a positive integer.
SSH_READY_TIMEOUT_MS=30000

# SSH keepalive interval in milliseconds. Use a positive integer; 20000 means 20 seconds.
SSH_KEEPALIVE_INTERVAL_MS=20000

# Route destination SSH/SFTP transfers through PROXY_URL.
# Allowed values: true, false, on, off.
DESTINATION_USE_PROXY=false

# Local Windows directory containing source backup files.
SOURCE_DIR=C:\Backups

# Case-insensitive filename pattern. Wildcards * and ? are supported.
# Examples: *.bak, *.zip, database-????.bak.
SOURCE_FILE_PATTERN=*.bak

# Transfer only the newest matching file by modification time. Allowed values: true, false, on, off.
SOURCE_LATEST_ONLY=true

# Ignore matching files newer than this many seconds to avoid uploading active files.
# Use 0 to disable the age delay, or a non-negative integer such as 60.
SOURCE_MIN_AGE_SECONDS=10

# Delete each source file only after its upload succeeds. Allowed values: true, false, on, off.
DELETE_SOURCE_ON_SUCCESS=false

# Compress each selected file as gzip level 9 before upload. Allowed values: true, false, on, off.
# The remote filename receives a .gz suffix; the original source file is not modified.
COMPRESSION=false

# Source cleanup strategy. Allowed values: off, time, count.
RETENTION_POLICY=off

# Maximum source file age when RETENTION_POLICY=time.
# Units: s=seconds, m=minutes, h=hours, d=days, w=weeks. Examples: 60m, 1d, 3w.
RETENTION_TIME=1d

# Number of newest matching source files to keep when RETENTION_POLICY=count.
# Use a positive integer such as 2.
RETENTION_COUNT=2

# Skip an unchanged file after it was transferred successfully. Allowed values: true, false, on, off.
# Keep true when DELETE_SOURCE_ON_SUCCESS=false to prevent repeated uploads.
SKIP_ALREADY_TRANSFERRED=true

# Telegram delivery mode. Allowed values: off, all, success, failures.
TELEGRAM_MODE=failures

# Channel used when a required Telegram delivery fails. Allowed values: off, email.
# Email settings must be valid when this is set to email.
TELEGRAM_FALLBACK=off

# Telegram Bot API base URL. Keep the default unless using a compatible API gateway.
TELEGRAM_API_URL=https://api.telegram.org

# Route Telegram API requests through PROXY_URL.
# Allowed values: true, false, on, off.
TELEGRAM_USE_PROXY=false

# Telegram bot token from BotFather. Required unless TELEGRAM_MODE=off and no email fallback uses Telegram.
TELEGRAM_BOT_TOKEN=

# Telegram destination chat ID. User IDs are positive; group/channel IDs are commonly negative.
TELEGRAM_CHAT_ID=

# Optional Telegram forum topic/message-thread ID. Leave empty for a normal chat.
TELEGRAM_TOPIC_ID=

# Email delivery mode. Allowed values: off, all, success, failures.
EMAIL_MODE=off

# Channel used when a required email delivery fails. Allowed values: off, telegram.
# Telegram settings must be valid when this is set to telegram.
EMAIL_FALLBACK=off

# Route SMTP delivery through PROXY_URL.
# Allowed values: true, false, on, off.
EMAIL_USE_PROXY=false

# SMTP server hostname or IP address.
SMTP_HOST=smtp.example.com

# SMTP port. Common values: 465 for implicit TLS, 587 for STARTTLS, 25 for plain/STARTTLS.
SMTP_PORT=465

# Use implicit TLS from connection start. Use true for port 465 and usually false for 587/25.
SMTP_SSL=true

# SMTP login username. Leave empty only when the server allows unauthenticated sending.
SMTP_USER=

# SMTP login password or application-specific password.
SMTP_PASSWORD=

# Sender address shown in the email From header.
EMAIL_FROM=backup-agent@example.com

# Required recipient list. Separate multiple addresses with commas or semicolons.
EMAIL_TO=admin@example.com

# Optional CC recipient list. Separate multiple addresses with commas or semicolons.
EMAIL_CC=

# Optional BCC recipient list. Separate multiple addresses with commas or semicolons.
EMAIL_BCC=

# Text prepended to notification email subjects.
EMAIL_SUBJECT_PREFIX=[backup-agent]
